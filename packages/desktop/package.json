{
  "name": "@frigg/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Frigg desktop shell (Electron)",
  "main": "dist/main.cjs",
  "scripts": {
    "build:main": "node esbuild.config.mjs",
    "dev": "npm run build:main && cross-env FRIGG_DESKTOP_DEV=1 electron .",
    "start": "npm run build:main && electron .",
    "dist": "npm run build:main && electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "*"
  },
  "devDependencies": {
    "@frigg/server": "*",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.24.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.frigg.app",
    "productName": "Frigg",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "electronVersion": "33.4.11",
    "npmRebuild": false,
    "beforePack": "scripts/before-pack.cjs",
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "files": [
      "dist/**"
    ],
    "extraResources": [
      {
        "from": "../web/dist",
        "to": "web"
      },
      {
        "from": "dist/mcp",
        "to": "mcp"
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  }
}
